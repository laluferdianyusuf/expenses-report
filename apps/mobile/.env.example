# API base URL (include /v1 prefix)
# Android emulator: use http://10.0.2.2:3000/v1
# iOS simulator / web: use http://localhost:3000/v1
# Physical device: use your machine LAN IP, e.g. http://192.168.1.10:3000/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/v1

# Dev Client — set API URL saat build via eas.json env atau EAS secrets
