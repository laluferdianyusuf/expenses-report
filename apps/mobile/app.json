{
  "expo": {
    "name": "FMS Enterprise",
    "slug": "fms-enterprise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fms",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fms.enterprise",
      "infoPlist": {
        "NSFaceIDUsageDescription": "FMS Enterprise menggunakan Face ID untuk login cepat dan aman.",
        "NSPhotoLibraryUsageDescription": "FMS Enterprise membutuhkan akses galeri untuk melampirkan bukti transaksi.",
        "NSCameraUsageDescription": "FMS Enterprise membutuhkan akses kamera untuk melampirkan bukti transaksi."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.fms.enterprise",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563EB",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan akses galeri untuk melampirkan bukti transaksi."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Izinkan FMS Enterprise menggunakan Face ID untuk login cepat."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#2563EB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
